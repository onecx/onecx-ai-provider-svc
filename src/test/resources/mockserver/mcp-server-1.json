          "method": "tools/list"
        }
      }
    },
    "httpResponse": {
      "body": {
        "type": "JSON",
        "contentType": "application/json",
        "json": {
          "jsonrpc": "2.0",
          "id": 2,
          "result": {
            "tools": [
              {
                name: "searchTest",
                description: "Search for available test",
                inputSchema: {
                  type: "object",
                  properties: {
                    name: { type: "string", description: "Name of the test" }
                  },
                  required: ["name"]
                }
              }
            ]
          }
        }
      }
    }
  },
  {
    "id": "mcp-server-1-tools-call",
    "priority": 10,
    "httpRequest": {
      "method": "POST",
      "headers": {
        "Authorization": [
          "api_key_1"
        ]
      },
      "path": "/mcp1",
      "body": {
        "type": "JSON",
        "matchType": "ONLY_MATCHING_FIELDS",
        "json": {
          "method": "tools/call"
        }
      }
    },
    "httpResponse": {
      "body": {
        "type": "JSON",
        "contentType": "application/json",
        "json": {
          "jsonrpc": "2.0",
          "id": 3,
          "result": {
            "content": [
              {
                "type": "text",
                "text": "searchTest executed successfully for name='Hallo'."
              },
              {
                "type": "json",
                "json": {
                  "query": "Hallo",
                  "matches": [
                    {
                      "id": "t-1001",
                      "label": "Hallo Welt",
                      "score": 0.91
                    },
                    {
                      "id": "t-1002",
                      "label": "Hallo (greeting)",
                      "score": 0.77
                    }
                  ],
                  "count": 2
                }
              }
            ],
            "isError": false
          }
        }
      }
    }
  }
