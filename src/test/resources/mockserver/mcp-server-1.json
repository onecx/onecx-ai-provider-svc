  {
    "id": "mcp-server-1-tools-list",
    "priority": 10,
    "httpRequest": {
      "method": "POST",
      "headers": {
        "Authorization": [
          "api_key_1"
        ]
      },
      "path": "/mcp1",
      "body": {
        "type": "JSON",
        "matchType": "ONLY_MATCHING_FIELDS",
