<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2026-06-26-default-lead-delegates" author="codex">
        <update tableName="agent_group">
            <column name="orchestration_mode" value="LEAD_DELEGATES"/>
            <where>orchestration_mode = 'SUPERVISOR_ROUTED'</where>
        </update>
        <addDefaultValue tableName="agent_group"
                         columnName="orchestration_mode"
                         columnDataType="VARCHAR(64)"
                         defaultValue="LEAD_DELEGATES"/>
    </changeSet>
</databaseChangeLog>
